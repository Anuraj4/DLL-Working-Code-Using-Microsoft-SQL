              }
            },
            {
              "name": "functionName",
              "value": {
                "type": "STRING",
                "string": "PDFToBase64"
              }
            },
            {
              "name": "arguments",
              "value": {
                "type": "VARIABLE",
                "variableName": "iStrFilePath"
              }
            }
