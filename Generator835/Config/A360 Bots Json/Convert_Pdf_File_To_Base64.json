    {
      "uid": "6ba0724b-72ba-4e5c-8f05-87eae36265da",
      "commandName": "try",
      "packageName": "ErrorHandler",
      "children": [
        {
          "uid": "a237eebe-71fa-4f35-82c5-0668f65f239f",
          "commandName": "vbscript.commands.openScript",
          "packageName": "VBScript",
          "disabled": false,
          "attributes": [
            {
              "name": "session",
              "value": {
                "type": "STRING",
                "string": "Default"
              }
            },
            {
              "name": "scriptOption",
              "value": {
                "type": "STRING",
                "string": "SCRIPT"
              }
            },
            {
              "name": "script",
              "value": {
                "type": "STRING",
                "string": "Function PDFToBase64(pdfFilePath)\n    Dim objStream, objXML, objNode\n    \n    \n    Set objStream = CreateObject(\"ADODB.Stream\")\n    objStream.Type = 1\n    objStream.Open\n    objStream.LoadFromFile pdfFilePath\n    \n    \n    Set objXML = CreateObject(\"MSXML2.DOMDocument.3.0\")\n    Set objNode = objXML.CreateElement(\"Base64Data\")\n    objNode.DataType = \"bin.base64\"\n    objNode.nodeTypedValue = objStream.Read\n    \n    \n    PDFToBase64 = Replace(Replace(objNode.text, vbCrLf, \"\"), vbLf, \"\")\n    \n    \n    objStream.Close\n    Set objStream = Nothing\n    Set objNode = Nothing\n    Set objXML = Nothing\nEnd Function"
              }
            }
          ]
        },
        {
          "uid": "5f32b10d-d8c0-42ad-97c3-d07b92489050",
          "commandName": "vbscript.commands.executeFunction",
          "packageName": "VBScript",
          "disabled": false,
          "attributes": [
