<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:EOB_TO_EDI_835.AvaloniaUI.ViewModels"
             xmlns:p1="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
             xmlns:p2="clr-namespace:Edi.Generator835.Pipeline;assembly=Edi.Generator835"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:core="clr-namespace:Xalta.Edi.BalancingValidation.Core;assembly=Xalta.Edi.BalancingValidation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="EOB_TO_EDI_835.AvaloniaUI.Views.ResultsView"
             x:DataType="vm:ResultsViewModel"
             x:CompileBindings="False">
    <Grid ColumnDefinitions="300, *">
        <!-- Results List -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource MaterialDividerBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Generation History" Classes="Subtitle1" Margin="16" />
                <ListBox ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}" Padding="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="p2:PipelineResult">
                            <Grid ColumnDefinitions="Auto, *" Margin="8">
                                <avalonia:MaterialIcon Kind="{Binding Success, Converter={StaticResource SuccessIconConverter}}" 
                                                       Foreground="{Binding Success, Converter={StaticResource SuccessColorConverter}}"
                                                       Width="18" Height="18" Margin="0,0,12,0" />
                                <TextBlock Grid.Column="1" Text="{Binding InputFilePath, Converter={StaticResource FileNameConverter}}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Result Details -->
        <Grid Grid.Column="1" Margin="24">
            <ScrollViewer>
                <Grid>
                    <!-- Detailed Result -->
                    <StackPanel Spacing="16" IsVisible="{Binding SelectedResult, Converter={StaticResource IsNotNullConverter}}">
                        <Border Classes="Card" Theme="{StaticResource MaterialCard}" Padding="24">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                    <TextBlock Text="{Binding SelectedResult.InputFilePath, Converter={StaticResource FileNameConverter}}" Classes="Headline5" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Command="{Binding OpenEditorCommand}" Classes="Flat" Margin="16,0" ToolTip.Tip="Open EDI Editor">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <avalonia:MaterialIcon Kind="FileEditOutline" Width="20" Height="20" />
                                            <TextBlock Text="EDIT EDI" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Content="PRINT PDF" Command="{Binding ExportToPdfCommand}" Classes="Outline" Margin="0,0,16,0" ToolTip.Tip="Export to Professional PDF" />
                                    <avalonia:MaterialIcon Grid.Column="3" 
                                                           Kind="{Binding SelectedResult.Success, Converter={StaticResource SuccessIconConverter}}" 
                                                           Foreground="{Binding SelectedResult.Success, Converter={StaticResource SuccessColorConverter}}"
                                                           Width="32" Height="32" />
                                </Grid>
                                <TextBlock Text="{Binding SelectedResult.InputFilePath}" Foreground="{DynamicResource MaterialBodyBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Validation Errors Section -->
                        <TextBlock Text="Validation Errors" Classes="Headline6" IsVisible="{Binding SelectedResult.ValidationErrors.Count}" />
                        <ItemsControl ItemsSource="{Binding SelectedResult.ValidationErrors}" IsVisible="{Binding SelectedResult.ValidationErrors.Count}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="core:ValidationError">
                                    <Border Background="#FFFDE7E7" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <avalonia:MaterialIcon Kind="AlertCircleOutline" Foreground="Red" Width="18" Height="18" VerticalAlignment="Top" />
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#C62828" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding !SelectedResult.ValidationErrors.Count}">
                            <avalonia:MaterialIcon Kind="CheckCircleOutline" Foreground="Green" Width="64" Height="64" Margin="0,32,0,16" HorizontalAlignment="Center" />
                            <TextBlock Text="No validation errors found." HorizontalAlignment="Center" Classes="Subtitle1" Foreground="Green" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsVisible="{Binding SelectedResult, Converter={StaticResource IsNullConverter}}">
                        <avalonia:MaterialIcon Kind="CursorDefaultOutline" Foreground="{DynamicResource MaterialDividerBrush}" Width="48" Height="48" Margin="0,0,0,16" />
                        <TextBlock Text="Select a result from the list to view details" Classes="Subtitle1" Foreground="{DynamicResource MaterialBodyLightBrush}" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Status Message -->
            <Border VerticalAlignment="Bottom" Background="{DynamicResource PrimaryMidBrush}" Padding="12,6"
                    IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotNullConverter}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="12" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
